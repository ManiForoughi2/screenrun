fastlane_version "2.220.0"

IOS_APP_ID = "com.manif.runs"
SCHEME     = "Runs"
PROJECT    = "Runs.xcodeproj"

# Resolve the .p8 key to an absolute path relative to the project root (one level
# up from this Fastfile), regardless of fastlane's working directory. ASC_KEY_PATH
# may be a bare filename (default) or an absolute path.
ASC_KEY_FILE = File.absolute_path?(ENV["ASC_KEY_PATH"].to_s) ?
  ENV["ASC_KEY_PATH"] :
  File.expand_path("../../#{ENV['ASC_KEY_PATH']}", __FILE__)

# ============================================================
# Runs — iOS screen-time app (App Store Connect)
#
# Auth is the shared App Store Connect API key (key_id/issuer_id/.p8) read from
# .env. Free app, no IAP. Family Controls distribution still requires Apple's
# entitlement grant before a build can pass review — see README.
# ============================================================
platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ASC_KEY_FILE,
      in_house:     false
    )
  end

  desc "Verify App Store Connect credentials and that the app record exists"
  lane :verify do
    require 'spaceship'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath:  ASC_KEY_FILE
    )
    app = Spaceship::ConnectAPI::App.find(IOS_APP_ID)
    if app
      UI.success "Connected. Found app: #{app.name} (#{app.bundle_id} / #{app.id})"
    else
      UI.error "Connected, but no app with bundle ID #{IOS_APP_ID} exists yet. Create it in App Store Connect first (see the create_app lane / asc)."
    end
  end

  desc "Create the App Store Connect app record if it doesn't exist (name + bundle id + primary language)"
  lane :create_app do
    produce(
      app_identifier: IOS_APP_ID,
      app_name:       "Runs: Screen Time & Focus",
      language:       "en-US",
      app_version:    "1.0",
      sku:            "runs-screentime-001"
    )
  end

  desc "Push metadata (name, subtitle, keywords, description, URLs) only — no build"
  lane :metadata do
    upload_to_app_store(
      app_identifier:     IOS_APP_ID,
      skip_binary_upload: true,
      skip_screenshots:   true,
      submit_for_review:  false,
      automatic_release:  false,
      force:              true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload App Store screenshots only (iPhone 6.9in + iPad 13in) — no build, no metadata"
  lane :screenshots do
    upload_to_app_store(
      app_identifier:        IOS_APP_ID,
      skip_binary_upload:    true,
      skip_metadata:         true,
      skip_screenshots:      false,
      overwrite_screenshots: true,
      submit_for_review:     false,
      automatic_release:     false,
      force:                 true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Set content rights (no third-party content) + export-compliance (no non-exempt encryption)"
  lane :content_rights do
    require 'spaceship'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath:  ASC_KEY_FILE
    )
    app = Spaceship::ConnectAPI::App.find(IOS_APP_ID)
    UI.user_error!("App #{IOS_APP_ID} not found") if app.nil?
    app.update(attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
    UI.success "Set contentRightsDeclaration = DOES_NOT_USE_THIRD_PARTY_CONTENT"
  end

  desc "Build, upload binary + metadata, but do NOT submit for review (stage it in ASC)"
  lane :release_no_submit do
    build_app(
      project:       PROJECT,
      scheme:        SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs:        "-allowProvisioningUpdates"
    )
    upload_to_app_store(
      app_identifier:     IOS_APP_ID,
      submit_for_review:  false,
      automatic_release:  false,
      skip_screenshots:   true,
      force:              true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Build, upload to TestFlight"
  lane :beta do
    build_app(
      project:       PROJECT,
      scheme:        SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs:        "-allowProvisioningUpdates"
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Build, upload, push metadata, and SUBMIT for App Store review"
  lane :release do
    build_app(
      project:       PROJECT,
      scheme:        SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs:        "-allowProvisioningUpdates"
    )
    upload_to_app_store(
      app_identifier:     IOS_APP_ID,
      submit_for_review:  true,
      automatic_release:  true,
      skip_screenshots:   true,
      force:              true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Upload a pre-built IPA (Xcode-archive fallback) + metadata, no review submission. Pass ipa:/path"
  lane :upload_ipa do |options|
    upload_to_app_store(
      app_identifier:     IOS_APP_ID,
      ipa:                options[:ipa],
      submit_for_review:  false,
      automatic_release:  false,
      skip_screenshots:   true,
      force:              true,
      precheck_include_in_app_purchases: false
    )
  end
end
